---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProfilePhoto from '../components/ProfilePhoto.astro';
import ProjectShowcase from '../components/ProjectShowcase.astro';
import RecentPostPreview from '../components/RecentPostPreview.astro';
import { getKnownImageDimensions } from '../lib/image-metadata-map';
import { getPostHref, getPublishedPosts, isExternalHref } from '../lib/posts';

const [latestPost] = await getPublishedPosts();
const latestPostHref = latestPost ? getPostHref(latestPost) : '/posts/';
const latestPostIsExternal = isExternalHref(latestPostHref);
const latestPostPreview = latestPost
  ? {
      href: latestPostHref,
      title: latestPost.data.title,
      description: latestPost.data.description,
      ogImage: latestPost.data.ogImage ?? null,
      ogImageAlt: latestPost.data.title,
      external: latestPostIsExternal,
    }
  : null;
const monashLogo = getKnownImageDimensions('/images/monash.svg')!;
const latrobeLogo = getKnownImageDimensions('/images/latrobe.png')!;
const jmssLogo = getKnownImageDimensions('/images/jmss-bw.webp')!;
---

<BaseLayout title="Shaunak Gadkari" description="Medical student and developer from Melbourne.">
  <div class="larger-text">
    <div class="intro">
      <div class="name-loc">
        <h1>Shaunak Gadkari</h1>
        <div class="sub">
          <span>Medical student & developer from Melbourne</span>
        </div>
      </div>

      <div class="photo">
        <ProfilePhoto />
      </div>
    </div>

    <h2>About me</h2>

    <p class="about">
      Hi, I'm Shaunak! I'm super interested in the intersection of medicine with AI and robotics.
    </p>

    {latestPostPreview ? (
      <RecentPostPreview {...latestPostPreview} />
    ) : (
      <p class="about">
        Recently I wrote about <a class="recent-post" href="/posts/">my latest writing</a> — <a href="/posts/">see all my writing</a>.
      </p>
    )}
  </div>

  <h2 id="education">Education</h2>

  <div class="education-list" aria-label="Education history">
    <article class="education-item">
      <div class="education-school">
        <div class="education-logo">
          <Image src="/images/monash.svg" alt="Monash University logo" width={monashLogo.width} height={monashLogo.height} />
        </div>
        <p class="education-name">Monash University</p>
      </div>

      <p class="education-degree">Doctor of Medicine (MD)</p>
      <p class="education-period mono">2023-2027</p>
    </article>

    <article class="education-item">
      <div class="education-school">
        <div class="education-logo">
          <Image src="/images/latrobe.png" alt="LaTrobe University logo" width={latrobeLogo.width} height={latrobeLogo.height} />
        </div>
        <p class="education-name">LaTrobe University</p>
      </div>

      <p class="education-degree">Master of Artificial Intelligence</p>
      <p class="education-period mono">2025-2027</p>
    </article>

    <article class="education-item is-complete">
      <div class="education-school">
        <div class="education-logo">
          <Image src="/images/jmss-bw.webp" alt="John Monash Science School logo" width={jmssLogo.width} height={jmssLogo.height} />
        </div>
        <p class="education-name">John Monash Science School</p>
      </div>

      <p class="education-degree">
        <span title="High school" class="hover-clarify">Victorian Certificate of Education</span>
      </p>
      <p class="education-period mono">2020-2022</p>
    </article>
  </div>

  <h2 id="projects">Projects</h2>
  <ProjectShowcase />

  <h2 id="skills">Skills</h2>

  <h3>Languages</h3>
  <ul>
    <li>JavaScript (ES6+) - both front-end and back-end (node.js, etc)</li>
    <li>Python - for data science/machine learning as well as web services</li>
    <li>Go - web services and CLIs</li>
    <li>HTML and CSS - for front-end development</li>
  </ul>

  <h3>Frameworks</h3>
  <ul>
    <li>React - front end UI</li>
    <li>Svelte - front end UI</li>
    <li>Next.js - full stack web applications</li>
    <li>Flask (Python) - web services and frameworks</li>
  </ul>

  <h2 id="about">About this site</h2>
  <p>
    This is my personal website. It's built with Astro and deployed on Cloudflare Pages.
  </p>

  <p>
    The footer image is of Point Ormond, St Kilda, Victoria.
  </p>
</BaseLayout>
