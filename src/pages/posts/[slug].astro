---
import { Image } from 'astro:assets';
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import PostFootnotes from '../../components/PostFootnotes.astro';
import PostHero from '../../components/PostHero.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import TagList from '../../components/TagList.astro';
import UtterancesComments from '../../components/UtterancesComments.astro';
import { mdxComponents } from '../../components/mdx';
import { getImageDimensions } from '../../lib/image-metadata';
import { getPostReadingTime, getPostSlug, getPublishedPosts, isPublishedPostPage } from '../../lib/posts';
import { formatDisplayDate, site } from '../../lib/site';
import { filterTocHeadings } from '../../lib/toc';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts
    .filter(isPublishedPostPage)
    .map((post) => ({ params: { slug: getPostSlug(post) }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const tocHeadings = filterTocHeadings(headings);
const readingTime = await getPostReadingTime(post);
const isOldPost = post.data.date.getUTCFullYear() < 2023;
const bodyClass = 'post-page';
const showToc = tocHeadings.length > 0;
const titleImageDimensions = post.data.useImageAsTitle
  ? await getImageDimensions(post.data.useImageAsTitle)
  : undefined;
const featureImageDimensions = post.data.featureImage
  ? await getImageDimensions(post.data.featureImage)
  : undefined;
const heroReplacesTitle = post.data.hero?.replaceTitle ?? false;
const pathLabel = `${site.domain}/posts/${getPostSlug(post)}`;
const dateLabel = formatDisplayDate(post.data.date);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.ogImage}
  ogImageAlt={post.data.title}
  article={true}
  publishedTime={post.data.date}
  featureImage={post.data.featureImage}
  tags={post.data.tags}
  bodyClass={bodyClass}
>
  {post.data.hero && (
    <PostHero
      title={post.data.title}
      authorLabel={site.author}
      pathLabel={pathLabel}
      dateLabel={dateLabel}
      hero={post.data.hero}
    />
  )}

  {!heroReplacesTitle && (post.data.useImageAsTitle ? (
    <h1 class="title title-image">
      {titleImageDimensions ? (
        <Image
          src={post.data.useImageAsTitle}
          alt={post.data.title}
          width={titleImageDimensions.width}
          height={titleImageDimensions.height}
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      ) : (
        <img src={post.data.useImageAsTitle} alt={post.data.title} loading="eager" decoding="async" fetchpriority="high" />
      )}
    </h1>
  ) : (
    <h1 class="title">{post.data.title}</h1>
  ))}

  <p class="subtitle">
    <span class="date">{formatDisplayDate(post.data.date)}</span>
    <span class="readtime">{readingTime} minute read</span>
  </p>

  {post.data.featureImage && (
    <figure class="feature-image">
      {featureImageDimensions ? (
        <Image
          src={post.data.featureImage}
          alt={`${post.data.title} feature image`}
          width={featureImageDimensions.width}
          height={featureImageDimensions.height}
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      ) : (
        <img src={post.data.featureImage} alt={`${post.data.title} feature image`} loading="eager" decoding="async" fetchpriority="high" />
      )}
    </figure>
  )}

  {isOldPost && (
    <div class="old-post-warning">
      <p><strong>Old post.</strong> Hi! Thanks for reading this older post. I wrote it back in high school, so you may run into broken links or out-of-date information.</p>
      <p>If you have any questions, just <a href="mailto:hi@srg.id.au">email me</a> and I'm happy to answer.</p>
    </div>
  )}

  <TagList tags={post.data.tags} />
  {showToc && <TableOfContents headings={tocHeadings} postTitle={post.data.title} variant="mobile" />}

  <div class={`post-layout ${showToc ? 'has-toc' : ''}`.trim()}>
    {showToc && <TableOfContents headings={tocHeadings} postTitle={post.data.title} variant="desktop" />}
    <article class="post-article">
      <Content components={mdxComponents} />
    </article>
    <PostFootnotes />
  </div>

  <NewsletterSignup variant="post-bottom" />

  {!post.data.disableComments && <UtterancesComments />}

  <a style="font-size: 0.8em" href="/posts/">&lt;- Back</a>
</BaseLayout>
