---
interface Props {
  src: string;
  alt?: string;
  type?: 'image' | 'video';
  autoplay?: boolean;
  loop?: boolean;
  muted?: boolean;
  videoType?: string;
}

const {
  src,
  alt = '',
  type = 'image',
  autoplay = false,
  loop = false,
  muted = false,
  videoType = 'video/mp4',
} = Astro.props;
---

<li class="carousel-slide" data-type={type}>
  <figure class="carousel-item">
    {type === 'video' ? (
      <video controls autoplay={autoplay} loop={loop} muted={muted} playsinline preload="metadata">
        <source src={src} type={videoType} />
        Your browser does not support the video tag.
      </video>
    ) : (
      <img src={src} alt={alt} loading="lazy" draggable="false" />
    )}

    <figcaption class="carousel-caption">
      <slot />
    </figcaption>
  </figure>
</li>
