---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface TocNode extends Heading {
  children: TocNode[];
}

interface Props {
  headings?: Heading[];
  postTitle: string;
  variant?: 'mobile' | 'desktop' | 'both';
}

const { headings = [], postTitle, variant = 'both' } = Astro.props;

function buildTree(source: Heading[]) {
  const root: TocNode[] = [];
  const stack: TocNode[] = [];

  for (const heading of source.filter((item) => item.depth <= 3)) {
    const node: TocNode = { ...heading, children: [] };
    while (stack.length && stack[stack.length - 1].depth >= node.depth) stack.pop();
    if (stack.length === 0) root.push(node);
    else stack[stack.length - 1].children.push(node);
    stack.push(node);
  }

  return root;
}

const toc = buildTree(headings);
---

{toc.length > 0 && (variant === 'mobile' || variant === 'both') && (
  <div
    class="mobile-toc-shell"
    data-mobile-toc
    data-mobile-collapsed-label="In this post"
    data-mobile-expanded-label="Table of contents"
    data-mobile-post-title={postTitle}
  >
    <div class="mobile-toc-inner">
      <button
        class="mobile-toc-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-toc-panel"
        data-mobile-toc-toggle
      >
        <span class="mobile-toc-meta">
          <span class="mobile-toc-label">In this post</span>
          <span class="mobile-toc-current-window" data-toc-current-window aria-live="polite" aria-atomic="true">
            <span class="mobile-toc-current-text">{toc[0]?.text}</span>
          </span>
        </span>
        <span class="mobile-toc-icon" aria-hidden="true"></span>
      </button>
      <div class="mobile-toc-panel-shell" id="mobile-toc-panel" aria-hidden="true" data-mobile-toc-panel>
        <div class="mobile-toc-panel-inner">
          <nav class="mobile-toc-panel-nav" aria-label="Table of contents" data-toc-nav="mobile">
            <ul>
              {toc.map((h1) => (
                <li>
                  <a href={`#${h1.slug}`}>{h1.text}</a>
                  {h1.children.length > 0 && (
                    <ul>
                      {h1.children.map((h2) => (
                        <li>
                          <a href={`#${h2.slug}`}>{h2.text}</a>
                          {h2.children.length > 0 && (
                            <ul>
                              {h2.children.map((h3) => (
                                <li>
                                  <a href={`#${h3.slug}`}>{h3.text}</a>
                                </li>
                              ))}
                            </ul>
                          )}
                        </li>
                      ))}
                    </ul>
                  )}
                </li>
              ))}
            </ul>
          </nav>
        </div>
      </div>
    </div>
  </div>
)}

{toc.length > 0 && (variant === 'desktop' || variant === 'both') && (
  <aside class="toc-rail" aria-label="Table of contents">
    <nav class="toc" data-toc-nav="desktop">
      <h4>Table of contents</h4>
      <ul>
        {toc.map((h1) => (
          <li>
            <a href={`#${h1.slug}`}>{h1.text}</a>
            {h1.children.length > 0 && (
              <ul>
                {h1.children.map((h2) => (
                  <li>
                    <a href={`#${h2.slug}`}>{h2.text}</a>
                    {h2.children.length > 0 && (
                      <ul>
                        {h2.children.map((h3) => (
                          <li>
                            <a href={`#${h3.slug}`}>{h3.text}</a>
                          </li>
                        ))}
                      </ul>
                    )}
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>
  </aside>
)}
