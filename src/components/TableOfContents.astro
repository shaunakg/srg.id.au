---
import TableOfContentsIsland from './react/TableOfContents';

interface Props {
  headings?: { depth: number; slug: string; text: string }[];
  postTitle: string;
  variant?: 'mobile' | 'desktop' | 'both';
}

const { headings = [], postTitle, variant = 'both' } = Astro.props;
---

<TableOfContentsIsland client:load headings={headings} postTitle={postTitle} variant={variant} />
