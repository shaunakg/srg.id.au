---
import { Image } from 'astro:assets';
import { ClientRouter, fade } from 'astro:transitions';
import '../styles.scss';
import { getKnownImageDimensions } from '../lib/image-metadata-map';
import { buildPageMetadata } from '../lib/metadata';
import { site } from '../lib/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  article?: boolean;
  publishedTime?: Date;
  featureImage?: string;
  tags?: string[];
  bodyClass?: string;
  noindex?: boolean;
}

const {
  title,
  description = site.description,
  ogImage,
  ogImageAlt,
  article = false,
  publishedTime,
  featureImage,
  tags = [],
  bodyClass = '',
  noindex = false,
} = Astro.props;

const siteUrl = Astro.site ?? new URL(`https://${site.domain}`);
const pathParts = Astro.url.pathname.split('/').filter(Boolean);
const shouldLoadAnalytics = Astro.url.hostname === siteUrl.hostname;
const footerImage = getKnownImageDimensions('/images/ormond.jpeg')!;
const metadata = buildPageMetadata({
  pathname: Astro.url.pathname,
  baseUrl: siteUrl,
  title,
  description,
  ogImage,
  ogImageAlt,
  article,
  publishedTime,
  featureImage,
  tags,
  noindex,
});
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#ffffff" />

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="RSS" href="/rss.xml" />
    <link rel="canonical" href={metadata.canonicalUrl} />
    <link rel="webmention" href="https://webmention.io/srg.id.au/webmention" />
    <link rel="pingback" href="https://webmention.io/srg.id.au/xmlrpc" />

    <title>{metadata.pageTitle}</title>
    <meta name="description" content={metadata.description} />
    <meta name="robots" content={metadata.robots} />
    <meta property="og:locale" content="en_AU" />
    <meta property="og:url" content={metadata.canonicalUrl} />
    <meta property="og:type" content={metadata.ogType} />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:title" content={metadata.socialTitle} />
    <meta property="og:description" content={metadata.description} />
    <meta property="og:image" content={metadata.ogImage} />
    <meta property="og:image:secure_url" content={metadata.ogImage} />
    <meta property="og:image:alt" content={metadata.ogImageAlt} />
    {metadata.ogImageMetadata?.width && <meta property="og:image:width" content={String(metadata.ogImageMetadata.width)} />}
    {metadata.ogImageMetadata?.height && <meta property="og:image:height" content={String(metadata.ogImageMetadata.height)} />}
    {metadata.ogImageMetadata?.mimeType && <meta property="og:image:type" content={metadata.ogImageMetadata.mimeType} />}
    {article && publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
    {article && <meta property="article:author" content={site.author} />}
    {article && tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={site.twitterHandle} />
    <meta name="twitter:creator" content={site.twitterHandle} />
    <meta name="twitter:title" content={metadata.socialTitle} />
    <meta name="twitter:description" content={metadata.description} />
    <meta name="twitter:url" content={metadata.canonicalUrl} />
    <meta name="twitter:image" content={metadata.ogImage} />
    <meta name="twitter:image:alt" content={metadata.ogImageAlt} />
    {metadata.structuredData && <script is:inline type="application/ld+json" set:html={metadata.structuredData} />}
    <ClientRouter />

    {shouldLoadAnalytics && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${site.analyticsId}`}></script>
        <script is:inline define:vars={{ analyticsId: site.analyticsId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){window.dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', analyticsId, { send_page_view: false });

          document.addEventListener('astro:page-load', () => {
            gtag('event', 'page_view', {
              page_location: window.location.href,
              page_path: window.location.pathname,
              page_title: document.title,
            });
          });
        </script>
      </>
    )}
  </head>
  <body class={bodyClass}>
    <div class="main">
      <div class="links" id="main-header">
        <div class="nav-group left path-nav">
          <a href="/"><b>~/srg</b></a>
          {
            pathParts.length === 0 ? (
              <span>/</span>
            ) : (
              pathParts.map((part, index) => {
                const href = `/${pathParts.slice(0, index + 1).join('/')}/`;
                return (
                  <>
                    <span>/</span>
                    <a href={href}>{part}</a>
                  </>
                );
              })
            )
          }
          {pathParts.length > 0 && <span>/</span>}
        </div>
        <div class="nav-group right">
          <a href="/posts/">posts</a>
          <a rel="me authn noopener noreferrer" href={site.github} target="_blank">github</a>
          <a rel="me noopener noreferrer" href={`mailto:${site.email}`} target="_blank">email</a>
          <a rel="me noopener noreferrer" style="display:none" href="https://social.srg.id.au/@sg" target="_blank">mastodon</a>
          <a rel="me noopener noreferrer" href={site.twitter} target="_blank">𝕏</a>
        </div>
      </div>

      <main class="page-content" transition:name="page-content" transition:animate={fade({ duration: '0.18s' })}>
        <slot />
      </main>
    </div>

    <footer class="page-footer" id="main-footer" style="--footer-gradient-height: 50%;" transition:persist>
      <Image
        class="page-footer-image"
        src="/images/ormond.jpeg"
        alt="Point Ormond, St Kilda, Victoria"
        width={footerImage.width}
        height={footerImage.height}
        loading="lazy"
        decoding="async"
      />
      <div class="page-footer-pill">
        © {new Date().getFullYear()} Shaunak Gadkari (srg) · <a rel="pgpkey" href="/pgp.txt">pgp public key</a>
      </div>
    </footer>
  </body>
</html>
